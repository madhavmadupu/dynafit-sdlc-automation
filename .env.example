# DYNAFIT Environment Configuration Variables

# ---------------------------------------------------------
# Application Settings
# ---------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---------------------------------------------------------
# Security
# ---------------------------------------------------------
# The API key required to access the FastAPI endpoints
API_KEY=dynafit_dev_secret_key_123

# Hourly rate limit per API key
API_RATE_LIMIT_PER_HOUR=100

# ---------------------------------------------------------
# LLM Provider (Anthropic)
# ---------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------
# Knowledge Base (Qdrant)
# ---------------------------------------------------------
# Use local Docker container for development by default
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ---------------------------------------------------------
# Relational DB & Historical Fitments (PostgreSQL w/ pgvector)
# ---------------------------------------------------------
# Use local Docker container for development by default
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dynafit

# ---------------------------------------------------------
# Caching & Rate Limiting (Redis)
# ---------------------------------------------------------
# Use local Docker container for development by default
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------
# Tracing & Observability (LangSmith)
# ---------------------------------------------------------
# LangSmith SaaS telemetry enabled
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=dynafit_local_dev
